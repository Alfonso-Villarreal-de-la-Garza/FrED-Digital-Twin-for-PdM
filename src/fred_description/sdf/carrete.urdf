<?xml version="1.0"?>
<robot name="FrED">

  <!-- BASE -->
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- PIEZA -->
  <link name="carrete">

    <!-- VISUAL -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/fonsivillarreal/DT/src/FD/meshes/carrete_pr.dae" scale="1 1 1"/>
      </geometry>
    </visual>

    <!-- COLLISION -->
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/fonsivillarreal/DT/src/FD/meshes/carrete_pr.dae" scale="1 1 1"/>
      </geometry>
    </collision>

    <!-- INERCIA -->
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

  </link>

  <!-- JOINT -->
  <joint name="base_to_carrete" type="fixed">
    <parent link="base_link"/>
    <child link="carrete"/>
    <origin xyz="0 0 0"/>
  </joint>

</robot>
